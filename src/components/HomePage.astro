---
import { copy, type Language } from "../data/site";
import HeroMapTile from "./HeroMapTile.astro";
import { heroDemoScene } from "../data/mapScenes";

type Props = {
  lang: Language;
};

const { lang } = Astro.props;
const t = copy[lang];
---

<section class="hero hero-centered shell">
  <div class="hero-simple">
    <p class="eyebrow">{t.hero.eyebrow}</p>
    <h1>{t.hero.title}</h1>
    <p class="lead">{t.hero.body}</p>
    <HeroMapTile scene={heroDemoScene} />
    <div class="hero-actions hero-actions-centered">
      <a class="button button-primary" href="#contact-form">{t.hero.primaryCta}</a>
    </div>
  </div>
</section>

<section class="section shell">
  <div class="section-heading section-heading-center">
    <h2>{t.home.process.title}</h2>
  </div>
  <div class="process-grid">
    {t.home.process.items.map((item, index) => (
      <article class="process-card">
        <p class="feature-index">0{index + 1}</p>
        <h3>{item.title}</h3>
        <p>{item.body}</p>
      </article>
    ))}
  </div>
</section>

<section class="section shell">
  <div class="faq-shell">
    <div class="section-heading section-heading-center">
      <h2>{t.home.faq.title}</h2>
    </div>
    <div class="faq-list">
      {t.home.faq.items.map((item) => (
        <details class="faq-item">
          <summary>{item.title}</summary>
          <p>{item.body}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<section class="section shell" id="contact-form">
  <div class="contact-card contact-card-centered">
    <div class="section-heading section-heading-center">
      <p class="section-kicker">{t.nav.contact}</p>
      <h2>{t.contact.title}</h2>
      <p>{t.contact.body}</p>
    </div>

    <form class="contact-form contact-form-simple">
      <label>
        <span>{t.contact.name}</span>
        <input type="text" name="name" />
      </label>
      <label>
        <span>{t.contact.email}</span>
        <input type="email" name="email" />
      </label>
      <label>
        <span>{t.contact.phone}</span>
        <input type="tel" name="phone" />
      </label>
      <label class="contact-form-full">
        <span>{t.contact.message}</span>
        <textarea name="message" rows="5"></textarea>
      </label>
      <button class="button button-primary" type="submit">{t.contact.submit}</button>
    </form>
  </div>
</section>
