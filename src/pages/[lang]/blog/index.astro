---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { copy, isLanguage, languages } from "../../../data/site";

export async function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!lang || !isLanguage(lang)) {
  return Astro.redirect("/en/");
}

const t = copy[lang];
const posts = (await getCollection("blog", ({ data }) => data.lang === lang)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout lang={lang} title={`Pluvii | ${t.blog.title}`}>
  <section class="page-hero shell">
    <div class="page-hero-panel">
      <p class="section-kicker">Blog</p>
      <h1>{t.blog.title}</h1>
      <p>{t.blog.intro}</p>
    </div>
  </section>

  <section class="section shell">
    <div class="content-list">
      {posts.length === 0 ? (
        <p>{t.blog.empty}</p>
      ) : (
        posts.map((post) => (
          <article class="list-item">
            <p class="meta">{post.data.publishDate.toISOString().slice(0, 10)}</p>
            <h2>
              <a href={`/${lang}/blog/${post.id.split("/").pop()?.replace(/\.md$/, "")}/`}>
                {post.data.title}
              </a>
            </h2>
            <p>{post.data.description}</p>
          </article>
        ))
      )}
    </div>
  </section>
</BaseLayout>
