export function getStaticPaths() {
  const audiences: Audience[] = ["landowners", "farmers", "municipalities"];

  return languages.flatMap((lang) =>
    audiences.map((audience) => ({
      params: { lang, audience }
    }))
  );
}

const { lang, audience } = Astro.params;

if (!lang || !isLanguage(lang) || !audience || !audienceIds.includes(audience as Audience)) {
  return Astro.redirect("/en/");
}

const typedAudience = audience as Audience;
const t = copy[lang];
const page = audienceContent[lang][typedAudience];
const heroImage = "/maps/las-grullas/preview.svg";
const galleryImages = ["/maps/las-grullas/flow-accumulation.png", "/maps/demo/preview.svg"];
---

<BaseLayout lang={lang} title={`Pluvii | ${t.nav.whoItsFor} | ${t.nav[typedAudience]}`}>
  <section class="audience-hero shell">
    <div class="audience-hero-stack">
      <p class="audience-kicker">
        {t.nav.whoItsFor} / {t.nav[typedAudience]}
      </p>
      <h1>{page.heroTitle}</h1>
      <p class="lead">{page.heroBody}</p>
      <figure class="audience-media audience-media-hero">
        <img src={heroImage} alt="Landscape preview map." loading="lazy" />
      </figure>
      <div class="audience-hero-actions">
        <a class="button button-primary" href={`/${lang}/#contact-form`}>
          {page.ctaLabel}
        </a>
        <a class="audience-hero-link" href="#audience-services">
          {page.servicesTitle}
        </a>
      </div>
    </div>
  </section>

  <section class="section shell audience-section" id="audience-services">
    <div class="audience-panel audience-context">
      <h2>{page.contextTitle}</h2>
      <p>{page.contextBody}</p>
    </div>
  </section>

  <section class="section shell audience-section">
    <div class="audience-panel">
      <h2>{page.outcomesTitle}</h2>
      <div class="audience-media-row">
        {galleryImages.map((imagePath) => (
          <figure class="audience-media">
            <img src={imagePath} alt="Project placeholder visual." loading="lazy" />
          </figure>
        ))}
      </div>
      <div class="audience-list">
        {page.outcomes.map((item) => (
          <article class="audience-item">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section shell audience-section">
    <div class="audience-panel">
      <h2>{page.servicesTitle}</h2>
      <div class="audience-list">
        {page.services.map((item) => (
          <article class="audience-item">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section shell audience-section">
    <div class="audience-panel">
      <h2>{page.processTitle}</h2>
      <ol class="audience-process">
        {page.process.map((step) => (
          <li class="audience-process-item">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section shell audience-section">
    <div class="audience-panel audience-deliverables">
      <h2>{page.deliverablesTitle}</h2>
      <ul>
        {page.deliverables.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <figure class="audience-media">
        <img src={galleryImages[0]} alt="Water accumulation overlay preview." loading="lazy" />
      </figure>
    </div>
  </section>

  <section class="section shell audience-section">
    <div class="audience-panel audience-cta">
      <h2>{page.ctaTitle}</h2>
      <p>{page.ctaBody}</p>
      <a class="button button-primary" href={`/${lang}/#contact-form`}>
        {page.ctaLabel}
      </a>
      <p class="audience-cta-link">
        <a href={`/${lang}/#contact-form`}>{t.nav.contact}</a>
      </p>
    </div>
  </section>
</BaseLayout>
